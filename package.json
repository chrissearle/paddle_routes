{
  "name": "paddle",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm cache:tracks && nuxt build",
    "cache:tracks": "tsx scripts/build-track-cache.mjs",
    "dev": "nuxt dev",
