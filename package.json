    "vue-router": "5.2.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.118",
    "@nuxt/eslint": "1.16.0",
    "@nuxt/fonts": "0.14.0",
    "@types/leaflet": "1.9.21",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vue-tsc": "3.3.7"
